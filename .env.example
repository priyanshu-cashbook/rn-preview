# -----------------------------------------------------------------------------
# Client-public vars (inlined into the JS bundle — do NOT put secrets here)
# -----------------------------------------------------------------------------

# URL of the deployed preview API server. Set this to the URL where the Expo
# Router `+api.ts` routes are hosted (EAS Hosting, Vercel, etc.). Leave empty to
# fall back to the seeded in-bundle deployment catalog (mock mode).
EXPO_PUBLIC_PREVIEW_API_URL=https://rn-preview-switcher.expo.app

# Revopush app names (display/metadata only on the client; the server uses the
# non-prefixed REVOPUSH_APP_NAME_* vars to talk to Revopush).
EXPO_PUBLIC_REVOPUSH_APP_NAME_IOS=SelfPreviewIOS
EXPO_PUBLIC_REVOPUSH_APP_NAME_ANDROID=SelfPreview

# Optional: public seed keys for offline mock mode (EXPO_PUBLIC_PREVIEW_API_URL
# empty). These are bundled into the JS, so only use deployment keys — never the
# admin access key.
EXPO_PUBLIC_REVOPUSH_PRODUCTION_KEY=
EXPO_PUBLIC_REVOPUSH_STAGING_KEY=

# -----------------------------------------------------------------------------
# Server-only vars (consumed by the Expo Router API route at
# src/app/deployments/list+api.ts — never exposed to the client). Configure
# these on your server host (EAS Hosting, Vercel, etc).
# -----------------------------------------------------------------------------

# Admin key used by the API route to list all deployments live from Revopush.
# Generate it in the Revopush UI (Settings → Add key). NEVER put this in a
# client-public EXPO_PUBLIC_* var.
REVOPUSH_ACCESS_KEY=

# Revopush app names — the API route uses these to call
# GET /apps/:appName/deployments per platform.
REVOPUSH_APP_NAME_ANDROID=SelfPreview
REVOPUSH_APP_NAME_IOS=SelfPreviewIOS

# Revopush API origin. Default is fine unless you self-host.
REVOPUSH_SERVER_URL=https://api.revopush.org

# Default native deployment key baked into the prebuild via
# plugins/with-revopush-sdk55.js. Usually the Staging key.
REVOPUSH_DEFAULT_DEPLOYMENT_KEY=

# Optional JSON array merged on top of the live Revopush list (same shape as
# the live response: { id, name, key }). Handy for one-off entries you don't
# want to create through the CLI. Example:
# REVOPUSH_DYNAMIC_DEPLOYMENTS='[{"id":"preview-pr-42","name":"preview-pr-42","key":"abc..."}]'
REVOPUSH_DYNAMIC_DEPLOYMENTS=

# -----------------------------------------------------------------------------
# GitHub Action secrets / variables (Repo Settings → Secrets and variables → Actions)
# -----------------------------------------------------------------------------
# Env-scoped (Settings → Environments → rn-preview):
#   Secret   REVOPUSH_ACCESS_KEY         → same admin key as above
#   Variable REVOPUSH_APP_NAME_ANDROID   → e.g. SelfPreview
#   Variable EXPO_PUBLIC_PREVIEW_API_URL → same as client-public var
#
# Repo-level (top-level Variables tab — required for the iOS job gate):
#   Variable REVOPUSH_APP_NAME_IOS       → e.g. SelfPreviewIOS (enables iOS job)
