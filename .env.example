# -----------------------------------------------------------------------------
# Client-public vars (inlined into the JS bundle — do NOT put secrets here)
# -----------------------------------------------------------------------------

# URL of the deployed preview API server. Set this to the URL where the Expo
# Router `+api.ts` routes are hosted (EAS Hosting, Vercel, etc.). Leave empty to
# fall back to the seeded in-bundle deployment catalog (mock mode).
EXPO_PUBLIC_PREVIEW_API_URL=

# Revopush app names (used by the GitHub Action and for display).
EXPO_PUBLIC_REVOPUSH_APP_NAME_IOS=SelfPreviewIOS
EXPO_PUBLIC_REVOPUSH_APP_NAME_ANDROID=SelfPreviewAndroid

# Optional: public seed keys used as a local fallback when the preview API is
# unreachable. These ARE bundled into the mobile app, so only use deployment
# keys (not admin access keys).
EXPO_PUBLIC_REVOPUSH_PRODUCTION_KEY=
EXPO_PUBLIC_REVOPUSH_STAGING_KEY=
EXPO_PUBLIC_REVOPUSH_PREVIEW_FEATURE_X_KEY=
EXPO_PUBLIC_REVOPUSH_PREVIEW_PAYMENTS_KEY=

# -----------------------------------------------------------------------------
# Server-only vars (used by the Expo Router API routes — never exposed to the
# client bundle). Configure these in your server host (EAS Hosting, Vercel, etc).
# -----------------------------------------------------------------------------

# Default native deployment key baked into the prebuild via
# plugins/with-revopush-sdk55.js. Usually the Staging key.
REVOPUSH_DEFAULT_DEPLOYMENT_KEY=
REVOPUSH_SERVER_URL=https://api.revopush.org

# Per-deployment keys returned by POST /deployments/list. Append _IOS or
# _ANDROID to scope a key to a single platform if needed.
REVOPUSH_PRODUCTION_KEY=
REVOPUSH_STAGING_KEY=
REVOPUSH_PREVIEW_FEATURE_X_KEY=
REVOPUSH_PREVIEW_PAYMENTS_KEY=

# Optional JSON array of extra deployments to surface in the app. Example:
# REVOPUSH_DYNAMIC_DEPLOYMENTS='[{"id":"preview-pr-42","name":"preview-pr-42","key":"abc..."}]'
REVOPUSH_DYNAMIC_DEPLOYMENTS=

# -----------------------------------------------------------------------------
# GitHub Action secrets (set via Repo Settings → Secrets and variables → Actions)
# -----------------------------------------------------------------------------
# Secret: REVOPUSH_ACCESS_KEY   → admin key from Revopush UI (Settings → Add key)
# Variable: REVOPUSH_APP_NAME_ANDROID → e.g. SelfPreviewAndroid
# Variable: REVOPUSH_APP_NAME_IOS     → e.g. SelfPreviewIOS (when you add iOS)
